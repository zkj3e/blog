{
  "name": "tech-blog",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "content": "tsx scripts/build-content.ts",
    "dev": "tsx scripts/build-content.ts && vite",
    "build": "tsx scripts/build-content.ts && vite build",
    "test": "node --import tsx --test scripts/**/*.test.ts",
    "wechat:export": "node --import tsx scripts/export-wechat-html.ts",
    "wechat:draft": "node --import tsx scripts/publish-wechat-article.ts",
    "postbuild": "node -e \"require('fs').copyFileSync('dist/index.html','dist/404.html')\"",
    "deploy": "npm run build && gh-pages -d dist",
    "preview": "vite preview"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "gh-pages": "^6.2.0",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "hast-util-to-string": "^3.0.1",
    "katex": "^0.16.45",
    "marked": "^12.0.1",
    "playwright-core": "^1.59.1",
    "postcss": "^8.4.35",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vite": "^5.1.0"
  }
}
